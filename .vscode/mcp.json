{
    "//": [
        "MCP servers for the Research Workflow Assistant.",
        "Each server loads API keys from .env automatically via python-dotenv.",
        "The command uses the venv Python explicitly so servers start correctly",
        "regardless of system PATH. Adjust the command path for your OS:",
        "  Windows:    ${workspaceFolder}/.venv/Scripts/python",
        "  macOS/Linux: ${workspaceFolder}/.venv/bin/python"
    ],
    "servers": {
        "pubmed": {
            "type": "stdio",
            "command": "${workspaceFolder}/.venv/Scripts/python",
            "args": [
                "-m",
                "pubmed_server"
            ],
            "cwd": "${workspaceFolder}/mcp-servers/pubmed-server/src"
        },
        "openalex": {
            "type": "stdio",
            "command": "${workspaceFolder}/.venv/Scripts/python",
            "args": [
                "-m",
                "openalex_server"
            ],
            "cwd": "${workspaceFolder}/mcp-servers/openalex-server/src"
        },
        "semantic-scholar": {
            "type": "stdio",
            "command": "${workspaceFolder}/.venv/Scripts/python",
            "args": [
                "-m",
                "semantic_scholar_server"
            ],
            "cwd": "${workspaceFolder}/mcp-servers/semantic-scholar-server/src"
        },
        "europe-pmc": {
            "type": "stdio",
            "command": "${workspaceFolder}/.venv/Scripts/python",
            "args": [
                "-m",
                "europe_pmc_server"
            ],
            "cwd": "${workspaceFolder}/mcp-servers/europe-pmc-server/src"
        },
        "crossref": {
            "type": "stdio",
            "command": "${workspaceFolder}/.venv/Scripts/python",
            "args": [
                "-m",
                "crossref_server"
            ],
            "cwd": "${workspaceFolder}/mcp-servers/crossref-server/src"
        },
        "zotero": {
            "type": "stdio",
            "command": "${workspaceFolder}/.venv/Scripts/python",
            "args": [
                "-m",
                "zotero_server"
            ],
            "cwd": "${workspaceFolder}/mcp-servers/zotero-server/src"
        },
        "prisma-tracker": {
            "type": "stdio",
            "command": "${workspaceFolder}/.venv/Scripts/python",
            "args": [
                "-m",
                "prisma_tracker"
            ],
            "cwd": "${workspaceFolder}/mcp-servers/prisma-tracker/src",
            "env": {
                "PROJECT_DIR": "${workspaceFolder}",
                "PROJECTS_ROOT": "${env:PROJECTS_ROOT}"
            }
        },
        "project-tracker": {
            "type": "stdio",
            "command": "${workspaceFolder}/.venv/Scripts/python",
            "args": [
                "-m",
                "project_tracker"
            ],
            "cwd": "${workspaceFolder}/mcp-servers/project-tracker/src",
            "env": {
                "PROJECT_DIR": "${workspaceFolder}",
                "PROJECTS_ROOT": "${env:PROJECTS_ROOT}"
            }
        },
        "zotero-local": {
            "type": "stdio",
            "command": "${workspaceFolder}/.venv/Scripts/python",
            "args": [
                "-m",
                "zotero_local_server"
            ],
            "cwd": "${workspaceFolder}/mcp-servers/zotero-local-server/src"
        }
    }
}