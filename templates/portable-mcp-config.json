{
    "//": [
        "Portable MCP config for using the Research Workflow Assistant from another project.",
        "Copy this file to your project's .vscode/mcp.json and update the paths below.",
        "Replace ASSISTANT_PATH with the absolute path to your research-workflow-assistant clone.",
        "Replace PYTHON_PATH with the path to the Python executable in the assistant's .venv."
    ],
    "servers": {
        "pubmed": {
            "command": "PYTHON_PATH",
            "args": [
                "-m",
                "pubmed_server"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/pubmed-server/src",
            "env": {
                "NCBI_API_KEY": "${env:NCBI_API_KEY}"
            }
        },
        "openalex": {
            "command": "PYTHON_PATH",
            "args": [
                "-m",
                "openalex_server"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/openalex-server/src",
            "env": {
                "OPENALEX_API_KEY": "${env:OPENALEX_API_KEY}"
            }
        },
        "semantic-scholar": {
            "command": "PYTHON_PATH",
            "args": [
                "-m",
                "semantic_scholar_server"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/semantic-scholar-server/src",
            "env": {
                "S2_API_KEY": "${env:S2_API_KEY}"
            }
        },
        "europe-pmc": {
            "command": "PYTHON_PATH",
            "args": [
                "-m",
                "europe_pmc_server"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/europe-pmc-server/src"
        },
        "crossref": {
            "command": "PYTHON_PATH",
            "args": [
                "-m",
                "crossref_server"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/crossref-server/src",
            "env": {
                "CROSSREF_EMAIL": "${env:CROSSREF_EMAIL}"
            }
        },
        "zotero": {
            "command": "PYTHON_PATH",
            "args": [
                "-m",
                "zotero_server"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/zotero-server/src",
            "env": {
                "ZOTERO_API_KEY": "${env:ZOTERO_API_KEY}",
                "ZOTERO_USER_ID": "${env:ZOTERO_USER_ID}"
            }
        },
        "prisma-tracker": {
            "command": "PYTHON_PATH",
            "args": [
                "-m",
                "prisma_tracker"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/prisma-tracker/src",
            "env": {
                "PROJECT_DIR": "${workspaceFolder}",
                "PROJECTS_ROOT": "${env:PROJECTS_ROOT}"
            }
        },
        "project-tracker": {
            "command": "PYTHON_PATH",
            "args": [
                "-m",
                "project_tracker"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/project-tracker/src",
            "env": {
                "PROJECT_DIR": "${workspaceFolder}",
                "PROJECTS_ROOT": "${env:PROJECTS_ROOT}"
            }
        }
    }
}