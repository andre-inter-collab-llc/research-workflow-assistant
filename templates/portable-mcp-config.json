{
    "//": [
        "Portable MCP config for using the Research Workflow Assistant from another project.",
        "Copy this file to your project's .vscode/mcp.json and update the path below.",
        "Replace ASSISTANT_PATH with the absolute path to your research-workflow-assistant clone.",
        "Each server loads API keys from ASSISTANT_PATH/.env automatically via python-dotenv.",
        "Adjust the python path for your OS:",
        "  Windows:     ASSISTANT_PATH/.venv/Scripts/python",
        "  macOS/Linux: ASSISTANT_PATH/.venv/bin/python"
    ],
    "servers": {
        "pubmed": {
            "type": "stdio",
            "command": "ASSISTANT_PATH/.venv/Scripts/python",
            "args": [
                "-m",
                "pubmed_server"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/pubmed-server/src"
        },
        "openalex": {
            "type": "stdio",
            "command": "ASSISTANT_PATH/.venv/Scripts/python",
            "args": [
                "-m",
                "openalex_server"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/openalex-server/src"
        },
        "semantic-scholar": {
            "type": "stdio",
            "command": "ASSISTANT_PATH/.venv/Scripts/python",
            "args": [
                "-m",
                "semantic_scholar_server"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/semantic-scholar-server/src"
        },
        "europe-pmc": {
            "type": "stdio",
            "command": "ASSISTANT_PATH/.venv/Scripts/python",
            "args": [
                "-m",
                "europe_pmc_server"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/europe-pmc-server/src"
        },
        "crossref": {
            "type": "stdio",
            "command": "ASSISTANT_PATH/.venv/Scripts/python",
            "args": [
                "-m",
                "crossref_server"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/crossref-server/src"
        },
        "zotero": {
            "type": "stdio",
            "command": "ASSISTANT_PATH/.venv/Scripts/python",
            "args": [
                "-m",
                "zotero_server"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/zotero-server/src"
        },
        "zotero-local": {
            "type": "stdio",
            "command": "ASSISTANT_PATH/.venv/Scripts/python",
            "args": [
                "-m",
                "zotero_local_server"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/zotero-local-server/src"
        },
        "prisma-tracker": {
            "type": "stdio",
            "command": "ASSISTANT_PATH/.venv/Scripts/python",
            "args": [
                "-m",
                "prisma_tracker"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/prisma-tracker/src",
            "env": {
                "PROJECT_DIR": "${workspaceFolder}",
                "PROJECTS_ROOT": "${env:PROJECTS_ROOT}"
            }
        },
        "project-tracker": {
            "type": "stdio",
            "command": "ASSISTANT_PATH/.venv/Scripts/python",
            "args": [
                "-m",
                "project_tracker"
            ],
            "cwd": "ASSISTANT_PATH/mcp-servers/project-tracker/src",
            "env": {
                "PROJECT_DIR": "${workspaceFolder}",
                "PROJECTS_ROOT": "${env:PROJECTS_ROOT}"
            }
        }
    }
}